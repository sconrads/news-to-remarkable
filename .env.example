# Schibsted-konto (brukes for VG, Aftenposten, E24)
SCHIBSTED_EMAIL=din@email.no
SCHIBSTED_PASSWORD=dittpassord

# Morgenbladet-konto (Piano). Kan være annen konto enn Schibsted.
# Utelat eller la stå tom for å bruke Schibsted-credentials som fallback.
MORGENBLADET_EMAIL=
MORGENBLADET_PASSWORD=

# Kalender (valgfritt) — kommaseparert liste med private ICS-URLer fra Google Calendar
# Finn URL: Google Calendar → tannhjul ved kalendernavnet → "Integrasjon" → "Hemmelig adresse i iCal-format"
# Eksempel med én kalender:
#   CALENDAR_ICS_URLS=https://calendar.google.com/calendar/ical/abc123%40group.calendar.google.com/private-xyz/basic.ics
CALENDAR_ICS_URLS=

# Ditt navn — vises på forsiden: "<OWNER_NAME>s nyhetsmorgen"
OWNER_NAME=Stian

# Mappe på reMarkable der PDFer lastes opp (standard: /Nyheter)
REMARKABLE_FOLDER=/Nyheter

# --- Kun for lokal kjøring / Pi ---
# Sti til cookie-cache (trenger ikke settes i GitHub Actions)
COOKIE_FILE=/home/sconrads/.news-remarkable-cookies.json
MORGENBLADET_COOKIE_FILE=/home/sconrads/.news-remarkable-cookies-morgenbladet.json
